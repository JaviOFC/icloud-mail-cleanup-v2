/* Execute screen layout */
#execute-content {
    height: 1fr;
    padding: 1;
}

#exec-description {
    text-align: center;
    height: auto;
    margin: 1 4;
    color: $text-muted;
}

#exec-summary {
    text-align: center;
    text-style: bold;
    height: 1;
    margin: 0 2;
}

#exec-buttons {
    align: center middle;
    height: 3;
    margin: 1 0;
}

#exec-buttons Button {
    margin: 0 2;
}

#exec-progress-row {
    height: auto;
    margin: 1 2;
    align: center middle;
}

#exec-progress {
    width: 1fr;
}

#exec-spinner {
    width: 4;
    height: 1;
    margin-left: 1;
}

#exec-stats {
    text-align: center;
    height: 1;
    margin: 0 4;
    color: $text-muted;
}

#exec-log {
    height: 1fr;
    margin: 1 2;
    border: solid $panel;
}

.hidden {
    display: none;
}
